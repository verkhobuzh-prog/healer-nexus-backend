# Healer Nexus — copy to .env and fill in values
# Get Telegram token: open Telegram → @BotFather → /newbot → name: Healer Nexus Bot → username: healer_nexus_bot

GEMINI_API_KEY=your_gemini_key_here
TELEGRAM_BOT_TOKEN=7123456789:AAHrL3Fxxxxxxxxxxxxxxxxxxxxxxxx
DATABASE_URL=sqlite+aiosqlite:///./healer.db?charset=utf8

# Optional — proxy if Telegram is blocked in your region
# TELEGRAM_PROXY=socks5://127.0.0.1:1080

PROJECT_ID=healer_nexus
BASE_URL=http://localhost:8000
ADMIN_CHAT_ID=
HEALER_SPECIALIST_BOT_TOKEN=
HEALER_CONSUMER_BOT_TOKEN=
DEBUG=false
