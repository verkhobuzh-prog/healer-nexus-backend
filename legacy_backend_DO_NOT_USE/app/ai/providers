import asyncio
import google.generativeai as genai
from typing import Dict, Any, List, Optional
from app.config import settings

class AIEngine:
    def __init__(self):
        self.model = None
        if settings.GOOGLE_AI_API_KEY:
            genai.configure(api_key=settings.GOOGLE_AI_API_KEY)
            self._setup_model()

    def _setup_model(self):
        try:
            # Пряма назва моделі без префіксів часто краще працює в WSL
            model_name = 'gemini-1.5-flash'
            print(f"🔄 Ініціалізація моделі: {model_name}...")
            self.model = genai.GenerativeModel(model_name)
            print(f"✅ AI ПІДКЛЮЧЕНО! (Локація: AT)")
        except Exception as e:
            print(f"❌ Помилка ініціалізації: {e}")

    async def call(self, prompt: str, history: List[Dict[str, str]] = None, image_data: Optional[bytes] = None) -> Dict[str, Any]:
        if not self.model:
            return {"text": "ШІ не активний."}
        try:
            parts = []
            if image_data:
                parts.append({"inline_data": {"mime_type": "image/jpeg", "data": image_data}})
            
            parts.append(f"Ти Healer & Creator Nexus. Відповідай українською.\n\nЗапит: {prompt}")

            loop = asyncio.get_event_loop()
            response = await loop.run_in_executor(None, lambda: self.model.generate_content(parts))
            return {"text": response.text}
        except Exception as e:
            return {"text": f"Помилка: {str(e)}"}

ai_engine = AIEngine()



