class ComponentHealth(BaseModel):
    """Individual component health status."""
    
    component: str = Field(..., example="postgresql")
    status: Literal["healthy", "degraded", "down", "not_configured", "unreachable"]
    latency_ms: float = Field(default=0.0, example=15.5)
    details: dict[str, Any] = Field(default_factory=dict)
    
    model_config = {
        "json_schema_extra": {
            "example": {
                "component": "postgresql",
                "status": "healthy",
                "latency_ms": 15.5,
                "details": {"query": "SELECT 1"}
            }
        }
    }


class DeepHealthResponse(BaseModel):
    """Deep health check response with all components."""
    
    overall_status: Literal["healthy", "degraded", "down"]
    components: list[ComponentHealth]
    summary: dict[str, int | float] = Field(
        ...,
        example={
            "total_components": 4,
            "healthy": 3,
            "degraded": 1,
            "down": 0,
            "average_latency_ms": 25.3
