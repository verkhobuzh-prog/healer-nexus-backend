"""
Application Configuration and Structured Logging Setup.

CRITICAL: Logging must be configured before any other imports.
"""
import os
import logging
from logging.handlers import RotatingFileHandler
from pathlib import Path
from pydantic_settings import BaseSettings
from dotenv import load_dotenv

# ============================================
# STEP 1: Create logs directory FIRST
# ============================================
logs_dir = Path("logs")
os.makedirs(logs_dir, exist_ok=True)


# ============================================
# STEP 2: Load environment variables
# ============================================
BASE_DIR = Path(__file__).parent.parent
load_dotenv(BASE_DIR / ".env")


# ============================================
# STEP 3: Define settings
# ============================================
class Settings(BaseSettings):
    """Application settings from environment variables."""
    
    # Core
    PROJECT_ID: str = "healer_nexus"
    DEBUG: bool = False
    
    # Database
    DATABASE_URL: str = "postgresql+asyncpg://postgres:postgres@localhost/healer_nexus"
    
    # AI
    GEMINI_API_KEY: str
    
    # Telegram
    TELEGRAM_BOT_TOKEN: str = ""
    ADMIN_CHAT_ID: str = ""
    
    # Redis (optional)
    REDIS_URL: str = "redis://localhost:6379/0"
    
    # Security
    SECRET_KEY: str = "change-me-in-production"
    
    model_config = {
        "env_file": str(BASE_DIR / ".env"),
        "env_file_encoding": "utf-8",
        "extra": "ignore"
    }


settings = Settings()


# ============================================
# STEP 4: Configure structured logging
# ============================================

class StructuredLogFilter(logging.Filter):
    """
    Inject project_id and module into every log record.
    
    This ensures all logs have consistent metadata for aggregation.
    """
    
    def filter(self, record):
        # Add project_id if not already present
        if not hasattr(record, 'project_id'):
            record.project_id = settings.PROJECT_ID
        
        # Add module if not present
        if not hasattr(record, 'module'):
            record.module = record.name.split('.')[-1]
        
        return True


# Configure root logger
logging.basicConfig(
    level=logging.DEBUG if settings.DEBUG else logging.INFO,
    format=(
        '%(asctime)s - %(name)s - %(levelname)s - '
        '%(message)s - [project_id=%(project_id)s] - [module=%(module)s]'
    ),
    handlers=[
        # File handler with rotation
        RotatingFileHandler(
            logs_dir / "healer_nexus.log",
            maxBytes=10_000_000,  # 10MB per file
            backupCount=5,  # Keep 5 backup files
            encoding='utf-8'
        ),
        # Console handler
        logging.StreamHandler()
    ]
)

# Add structured filter to all handlers
root_logger = logging.getLogger()
structured_filter = StructuredLogFilter()

for handler in root_logger.handlers:
    handler.addFilter(structured_filter)


# ============================================
# STEP 5: Validation
# ============================================
if not settings.GEMINI_API_KEY:
    logging.warning(
        "GEMINI_API_KEY not found in environment - AI features will fail",
        extra={"project_id": settings.PROJECT_ID, "module": "config"}
    )
else:
    logging.info(
        f"Configuration loaded successfully",
        extra={
            "project_id": settings.PROJECT_ID,
            "module": "config",
            "debug_mode": settings.DEBUG
        }
    )
