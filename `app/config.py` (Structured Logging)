## ✅ INTEGRATION EXAMPLE
```python
# app/main.py

from contextlib import asynccontextmanager
from fastapi import FastAPI
import asyncio
import logging

from app.config import settings  # Logging configured here
from app.database.connection import init_db, get_db
from app.core.event_bus import get_event_bus
from app.api.health import router as health_router

logger = logging.getLogger(__name__)


@asynccontextmanager
async def lifespan(app: FastAPI):
    """FastAPI lifecycle management."""
    
    # Startup
    logger.info(
        "🚀 Starting Healer Nexus Platform",
        extra={"project_id": settings.PROJECT_ID, "module": "main"}
    )
    
    # Initialize database
    await init_db()
    logger.info("✅ Database initialized")
    
    # Initialize EventBus
    event_bus = await get_event_bus(settings.PROJECT_ID)
    await event_bus.connect()
    app.state.event_bus = event_bus
    
    # Start EventBus listener in background
    listener_task = asyncio.create_task(event_bus.listen())
    app.state.listener_task = listener_task
    
    logger.info("✅ EventBus connected and listening")
    
    yield
    
    # Shutdown
    logger.info("🛑 Shutting down gracefully")
    
    if hasattr(app.state, 'event_bus'):
        await app.state.event_bus.disconnect()
    
    if hasattr(app.state, 'listener_task'):
        app.state.listener_task.cancel()


app = FastAPI(
    title="Healer Nexus Platform",
    version="2.0.0",
    lifespan=lifespan
)

# Register routers
app.include_router(health_router, prefix="/api", tags=["Health"])
