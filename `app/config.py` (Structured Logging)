"""
Health Check API Endpoints.

Provides quick and deep health checks for monitoring.
"""
from fastapi import APIRouter, Depends
from sqlalchemy.ext.asyncio import AsyncSession
from datetime import datetime, timezone
import logging

from app.database.connection import get_db
from app.schemas.responses import DeepHealthResponse, ComponentHealth
from app.core.health_checker import HealthChecker
from app.config import settings

router = APIRouter()
logger = logging.getLogger(__name__)


@router.get("/health")
async def quick_health_check():
    """
    Quick health check (no DB query).
    
    Returns:
        Simple OK response for load balancer health checks
    """
    return {"status": "ok", "timestamp": datetime.now(timezone.utc).isoformat()}


@router.get("/health/deep", response_model=DeepHealthResponse)
async def deep_health_check(db: AsyncSession = Depends(get_db)):
    """
    Comprehensive health check with parallel component verification.
    
    Checks:
    - PostgreSQL (latency measurement)
    - Gemini AI API (availability)
    - Telegram Bot API (connectivity)
    - Redis (optional, if configured)
    
    Uses Python 3.13 asyncio.TaskGroup for concurrent execution.
    """
    checker = HealthChecker(project_id=settings.PROJECT_ID)
    
    try:
        # Get AI client
        from app.ai.providers import get_ai_provider
        ai_provider = get_ai_provider()
        ai_client = ai_provider.client
        
        # Run all checks in parallel
        components = await checker.run_all_checks(
            db=db,
            ai_client=ai_client,
            bot_token=settings.TELEGRAM_BOT_TOKEN or ""
        )
        
        # Determine overall status
        statuses = [c["status"] for c in components]
        
        if "down" in statuses:
            overall = "down"
        elif "degraded" in statuses:
            overall = "degraded"
        else:
            overall = "healthy"
        
        # Calculate summary
        latencies = [c.get("latency_ms", 0.0) for c in components]
        avg_latency = sum(latencies) / len(latencies) if latencies else 0.0
        
        summary = {
            "total_components": len(components),
            "healthy": statuses.count("healthy"),
            "degraded": statuses.count("degraded"),
            "down": statuses.count("down"),
            "average_latency_ms": round(avg_latency, 2)
        }
        
        logger.info(
            f"Deep health check completed: {overall}",
            extra={
                "project_id": settings.PROJECT_ID,
                "module": "health_api",
                "overall_status": overall,
                "summary": summary
            }
        )
        
        return DeepHealthResponse(
            overall_status=overall,
            components=[ComponentHealth(**c) for c in components],
            summary=summary,
            timestamp=datetime.now(timezone.utc).isoformat()
        )
        
    except Exception as e:
        logger.error(
            f"Deep health check failed: {type(e).__name__}: {e}",
            exc_info=True,
            extra={"project_id": settings.PROJECT_ID, "module": "health_api"}
        )
        
        # Return degraded status instead of crashing
        return DeepHealthResponse(
            overall_status="down",
            components=[
                ComponentHealth(
                    component="system",
                    status="down",
                    latency_ms=0.0,
                    details={"error": str(e), "error_type": type(e).__name__}
                )
            ],
            summary={"total_components": 1, "healthy": 0, "degraded": 0, "down": 1, "average_latency_ms": 0.0},
            timestamp=datetime.now(timezone.utc).isoformat()
        )
